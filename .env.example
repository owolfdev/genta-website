# ChatIQ — server only (never NEXT_PUBLIC_*)
CHATIQ_API_KEY=sk_live_...
CHATIQ_BOT_SLUG=your-genta-bot-slug

# Optional override (default: https://www.chatiq.io/api)
# CHATIQ_API_BASE_URL=https://www.chatiq.io/api

# On load the shell calls POST /api/chat with ChatIQ’s welcome pattern:
# { "message": "", "is_welcome": true, "stream": false } (proxied to chatiq.io with bot_slug).

# Supabase — waitlist table `genta_waitlist` (server uses service role; never expose service key to the client)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (optional until you add client-side Supabase usage)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Waitlist — optional extra forward after Supabase insert: POST JSON { email, source }
# WAITLIST_WEBHOOK_URL=https://...
# WAITLIST_WEBHOOK_BEARER=optional-secret
